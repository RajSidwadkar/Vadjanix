# Containerfile.brain
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install --include=dev

# Copy source code
COPY . .

# Environment variables
ENV NODE_ENV=production
ENV ROUTER_URL=http://router:3000

# The brain entrypoint (assuming a future script to run the engine/brain layer)
CMD ["npx", "tsx", "src/brain/engine.ts"]
