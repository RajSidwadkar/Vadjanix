# Containerfile.router
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install --include=dev

# Copy source code
COPY . .

# Environment variables
ENV NODE_ENV=production
ENV VADJANIX_PUBKEY=dummy_hex_key

# The router entrypoint (hardened HTTP server)
EXPOSE 3000
CMD ["npx", "tsx", "src/router/server.ts"]
